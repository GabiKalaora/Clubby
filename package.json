{
  "name": "clubby",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "portal": "npm run dev --workspace=apps/portal",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > packages/shared/types/database.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
