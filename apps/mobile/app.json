{
  "expo": {
    "name": "Clubby",
    "slug": "clubby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "clubby",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clubby.mobile"
    },
    "android": {
      "package": "com.clubby.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "clubby"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#2ecc71"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Clubby to access your camera to scan QR codes."
        }
      ],
      "expo-localization",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
